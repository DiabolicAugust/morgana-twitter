
model LegendComment{
      id String @id @default(cuid())

legend Legend @relation(fields: [legendId], references: [id])
legendId String @map("legend_id")

user User @relation(fields: [userId], references: [id])
userId String @map("user_id")

text String 

replyTo   LegendComment? @relation("CommentReplies", fields: [replyToId], references: [id])
  replyToId String?

   replies   LegendComment[] @relation("CommentReplies")


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 


  @@map("legend_comment")
}